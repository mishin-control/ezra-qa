# Ezra QA - Environment Configuration
# Copy this file to .env and fill in values

# Staging environment base URL
E2E_BASE_URL=https://myezra-staging.ezra.com

# Admin/hub portal (used for cross-referencing member data)
HUB_BASE_URL=https://staging-hub.ezra.com

# Hub portal credentials (provided by Ezra)
HUB_USERNAME=
HUB_PASSWORD=

# API base URL (observed from network traffic)
API_BASE_URL=https://stage-api.ezra.com
